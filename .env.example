# Public application URL. Use the deployed HTTPS origin in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required server-only secret key from Supabase project settings > API.
# Never prefix this value with NEXT_PUBLIC_ or expose it to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Required OpenAI project API key and supported Responses API model.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Required for paid billing. Keep test values together or live values together.
# STRIPE_WEBHOOK_SECRET is the whsec_ value for this exact endpoint/listener.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=