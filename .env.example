# Public application URL. Use the deployed HTTPS origin in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only key. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI server-only configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Stripe server-only configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=