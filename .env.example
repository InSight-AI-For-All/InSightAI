# Public application URL. Use the deployed HTTPS origin in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required server-only secret key from Supabase project settings > API.
# Never prefix this value with NEXT_PUBLIC_ or expose it to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Required random 32+ character secret for the scheduled alert evaluator.
ADMIN_CRON_SECRET=
# Optional incident-change webhook and bearer secret (Slack/PagerDuty/email relay).
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=

# Required OpenAI project API key and supported Responses API model.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Required for paid billing. Keep test values together or live values together.
# STRIPE_WEBHOOK_SECRET is the whsec_ value for this exact endpoint/listener.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Existing $4.99 price, retained only for current subscribers. Leave empty on a fresh setup.
STRIPE_STARTER_PRICE_ID=
# New prices used by checkout.
STRIPE_STARTER_399_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_MAX_PRICE_ID=